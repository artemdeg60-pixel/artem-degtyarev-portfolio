}\cell\pard\intbl\itap1{\fs50\b \uc0\u1044 \uc0\u1077 \uc0\u1075 \uc0\u1090 \uc0\u1103 \uc0\u1088 \uc0\u1077 \uc0\u1074  \uc0\u1040 \uc0\u1088 \uc0\u1090 \uc0\u1105 \uc0\u1084  }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1052 \uc0\u1091 \uc0\u1078 \uc0\u1095 \uc0\u1080 \uc0\u1085 \uc0\u1072 }\par\pard\intbl\sl260{\fs18 \par +7\uc0\u160 (929)\uc0\u160 7816246 {\cf1\emdash  \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1087 \uc0\u1086 \uc0\u1095 \uc0\u1080 \uc0\u1090 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1086 \uc0\u1073  \uc0\u1089 \uc0\u1074 \uc0\u1103 \uc0\u1079 \uc0\u1080 }\par {{\field{\*\fldinst HYPERLINK "mailto:artemdeg60@gmail.com"}{\fldrslt\ul artemdeg60@gmail.com}}}\par telegram: @Naqiho221}\par\pard\intbl\sl260{\fs18 \par \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1077 \uc0\u1090 : \uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1074 \uc0\u1072 \par \uc0\u1043 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 : \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1103 \par \uc0\u1043 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1077 \uc0\u1077 \uc0\u1079 \uc0\u1076 \uc0\u1091 , \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1082  \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1082 \uc0\u1080 \uc0\u1084  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1072 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1077 \uc0\u1084 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1088 \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1072 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa100\sl280{\fs24\b Junior \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  | \uc0\u1040 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1085 \uc0\u1090  \uc0\u1088 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074  (AI, ML)}\pard\intbl\itap1\sl260{\fs18 \par{\uc0\u1057 \uc0\u1087 \uc0\u1077 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 :  }\par\li300{\uc0\u8212   \uc0\u1056 \uc0\u1091 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 }\par\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1058 \uc0\u1080 \uc0\u1087  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 : \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1085 \uc0\u1103 \uc0\u1090 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 /\uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1086 \uc0\u1077  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 \par \uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1083 \uc0\u1105 \uc0\u1085 \uc0\u1085 \uc0\u1086 , \uc0\u1075 \uc0\u1080 \uc0\u1073 \uc0\u1088 \uc0\u1080 \uc0\u1076 , \uc0\u1085 \uc0\u1072 \uc0\u160 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1077  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \par \line\uc0\u1046 \uc0\u1077 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103  \uc0\u1074  \uc0\u1087 \uc0\u1091 \uc0\u1090 \uc0\u1080  \uc0\u1076 \uc0\u1086  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099 : \uc0\u1085 \uc0\u1077  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1077 \uc0\u1090  \uc0\u1079 \uc0\u1085 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 }}\cell \row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1087 \uc0\u1099 \uc0\u1090  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \emdash 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\row\trowd\cellx1400\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1053 \uc0\u1086 \uc0\u1103 \uc0\u1073 \uc0\u1088 \uc0\u1100  2024 \emdash  \uc0\u1085 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1086 \uc0\u1103 \uc0\u1097 \uc0\u1077 \uc0\u1077  \uc0\u1074 \uc0\u1088 \uc0\u1077 \uc0\u1084 \uc0\u1103 \line 1 \uc0\u1075 \uc0\u1086 \uc0\u1076  7 \uc0\u1084 \uc0\u1077 \uc0\u1089 \uc0\u1103 \uc0\u1094 \uc0\u1077 \uc0\u1074 }\cell\pard\intbl\itap1\par\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1057 \uc0\u1077 \uc0\u1090 \uc0\u1100  \uc0\u1084 \uc0\u1072 \uc0\u1075 \uc0\u1072 \uc0\u1079 \uc0\u1080 \uc0\u1085 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1083 \uc0\u1086 \uc0\u1084 \uc0\u1073 \uc0\u1072 \uc0\u1088 \uc0\u1076 \uc0\u1086 \uc0\u1074  \uc0\u1047 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1081  \uc0\u1057 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1090 }\par\pard\intbl\itap1\sl260{\fs18\cf1 \uc0\u1042 \uc0\u1086 \uc0\u1083 \uc0\u1078 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  (\uc0\u1042 \uc0\u1086 \uc0\u1083 \uc0\u1075 \uc0\u1086 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1076 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1100 )}\par{\fs18 \uc0\u1056 \uc0\u1086 \uc0\u1079 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1086 \uc0\u1088 \uc0\u1075 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1103 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1056 \uc0\u1086 \uc0\u1079 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1100  (\uc0\u1102 \uc0\u1074 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1080 \uc0\u1079 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1103 )}}\par\li300{{\fs18 \uc0\u8226  \uc0\u1056 \uc0\u1086 \uc0\u1079 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1089 \uc0\u1077 \uc0\u1090 \uc0\u1100  (\uc0\u1101 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 , \uc0\u1073 \uc0\u1099 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1103  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1080 \uc0\u1082 \uc0\u1072 )}}\par {\fs18 \uc0\u1060 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1081  \uc0\u1089 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1088 }\par\li300{{\fs18 \uc0\u8226  \uc0\u1060 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1086 \uc0\u1074 \uc0\u1086 -\uc0\u1082 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1089 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1085 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  (\uc0\u1073 \uc0\u1080 \uc0\u1088 \uc0\u1078 \uc0\u1072 , \uc0\u1073 \uc0\u1088 \uc0\u1086 \uc0\u1082 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1077 \uc0\u1103 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100 , \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082  \uc0\u1080  \uc0\u1086 \uc0\u1073 \uc0\u1089 \uc0\u1083 \uc0\u1091 \uc0\u1078 \uc0\u1080 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1072 \uc0\u1088 \uc0\u1090 , \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1082 \uc0\u1072  \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1074 , \uc0\u1086 \uc0\u1073 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1091 \uc0\u1085 \uc0\u1082 \uc0\u1090 \uc0\u1099 , \uc0\u1072 \uc0\u1075 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1072  \uc0\u1087 \uc0\u1086  \uc0\u1082 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1080 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1102 , \uc0\u1080 \uc0\u1085 \uc0\u1082 \uc0\u1072 \uc0\u1089 \uc0\u1089 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 , \uc0\u1083 \uc0\u1086 \uc0\u1084 \uc0\u1073 \uc0\u1072 \uc0\u1088 \uc0\u1076 , \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1078 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099 )}}\par \pard\intbl\itap1\sl280\sb60\sa60{\fs24 \uc0\u1050 \uc0\u1086 \uc0\u1086 \uc0\u1088 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1088  \uc0\u1086 \uc0\u1087 \uc0\u1077 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u