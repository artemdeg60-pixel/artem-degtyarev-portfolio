\uc0\u1103 .{\line}{\line}\uc0\u1047 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 :{\line}-\uc0\u1040 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1087 \uc0\u1086 \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1081  \uc0\u1082 \uc0\u1083 \uc0\u1080 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1092 \uc0\u1080 \uc0\u1090 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 {\line}-\uc0\u1060 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1058 \uc0\u1047 {\line}-\uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1093  \uc0\u1089 \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1080 \uc0\u1077 \uc0\u1074  \uc0\u1080  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1088 \uc0\u1092 \uc0\u1077 \uc0\u1081 \uc0\u1089 \uc0\u1072 {\line}-\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1092 \uc0\u1091 \uc0\u1085 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1072  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1080 \uc0\u1089 \uc0\u1080  \uc0\u1085 \uc0\u1072  \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1085 \uc0\u1077 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1086 \uc0\u1084 {\line}-\uc0\u1048 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1091 \uc0\u1074 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1084 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1081  \uc0\u1080  \uc0\u1076 \uc0\u1086 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1093  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1074 \uc0\u1080 \uc0\u1089 \uc0\u1086 \uc0\u1074 {\line}-\uc0\u1058 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 , \uc0\u1088 \uc0\u1077 \uc0\u1083 \uc0\u1080 \uc0\u1079  \uc0\u1080  \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1074  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091  \uc0\u1092 \uc0\u1080 \uc0\u1090 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 .{\line}{\line}\uc0\u1048 \uc0\u1090 \uc0\u1086 \uc0\u1075 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 :{\line}-\uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072 \uc0\u1085 \uc0\u1072  \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1094 \uc0\u1077 \uc0\u1087 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1084 \uc0\u1086 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1092 \uc0\u1080 \uc0\u1090 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 {\line}-\uc0\u1057 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1099  \uc0\u1090 \uc0\u1088 \uc0\u1077 \uc0\u1073 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1082  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1091  \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1100 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1077  \uc0\u1089 \uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1072 \uc0\u1088 \uc0\u1080 \uc0\u1080 {\line}-\uc0\u1055 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1099  \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1072 \uc0\u1088 \uc0\u1090 \uc0\u1077 \uc0\u1092 \uc0\u1072 \uc0\u1082 \uc0\u1090 \uc0\u1099  \uc0\u1080  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 {\line}-\uc0\u1057 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1099  \uc0\u1073 \uc0\u1102 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1090 , \uc0\u1088 \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1087 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1080  \uc0\u1101 \uc0\u1092 \uc0\u1092 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1080 \uc0\u1074 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 {\line}-\uc0\u1054 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1072  \uc0\u1073 \uc0\u1080 \uc0\u1079 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1084 \uc0\u1086 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1100  \uc0\u1080  \uc0\u1101 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1086 \uc0\u1084 \uc0\u1080 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1094 \uc0\u1077 \uc0\u1083 \uc0\u1077 \uc0\u1089 \uc0\u1086 \uc0\u1086 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1085 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1100  \uc0\u1088 \uc0\u1077 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 {\line}-\uc0\u1055 \uc0\u1086 \uc0\u1076 \uc0\u1075 \uc0\u1086 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1072  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1079 \uc0\u1072 \uc0\u1087 \uc0\u1091 \uc0\u1089 \uc0\u1082 \uc0\u1072  \uc0\u1080  \uc0\u1074 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1088 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 {\line}{\line}{\line}\uc0\u1042  \uc0\u1088 \uc0\u1072 \uc0\u1084 \uc0\u1082 \uc0\u1072 \uc0\u1093  \uc0\u1090 \uc0\u1077 \uc0\u1082 \uc0\u1091 \uc0\u1097 \uc0\u1077 \uc0\u1081  \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1080  \uc0\u1074 \uc0\u1099 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1103 \uc0\u1102  \uc0\u1092 \uc0\u1091 \uc0\u1085 \uc0\u1082 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1073 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1082 \uc0\u1080 \uc0\u1077  \uc0\u1082  project management: \uc0\u1082 \uc0\u1086 \uc0\u1086 \uc0\u1088 \uc0\u1076 \uc0\u1080 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1091  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1099 , \uc0\u1088 \uc0\u1072 \uc0\u1089 \uc0\u1087 \uc0\u1088 \uc0\u1077 \uc0\u1076 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1102  \uc0\u1079 \uc0\u1072 \uc0\u1076 \uc0\u1072 \uc0\u1095 \uc0\u1080 , \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1080 \uc0\u1088 \uc0\u1091 \uc0\u1102  \uc0\u1089 \uc0\u1088 \uc0\u1086 \uc0\u1082 \uc0\u1080  \uc0\u1080  \uc0\u1082 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086  \uc0\u1080 \uc0\u1089 \uc0\u1087 \uc0\u1086 \uc0\u1083 \uc0\u1085 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 , \uc0\u1091 \uc0\u1095 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1091 \uc0\u1102  \uc0\u1074  \uc0\u1091 \uc0\u1083 \uc0\u1091 \uc0\u1095 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1080  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1094 \uc0\u1077 \uc0\u1089 \uc0\u1089 \uc0\u1086 \uc0\u1074  \uc0\u1080  \uc0\u1086 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1095 \uc0\u1072 \uc0\u1102  \uc0\u1079 \uc0\u1072  \uc0\u1076 \uc0\u1086 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1088 \uc0\u1077 \uc0\u1079 \uc0\u1091 \uc0\u1083 \uc0\u1100 \uc0\u1090 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1074  \uc0\u1087 \uc0\u1086  \uc0\u1082 \uc0\u1083 \uc0\u1102 \uc0\u1095 \uc0\u1077 \uc0\u1074 \uc0\u1099 \uc0\u1084  \uc0\u1087 \uc0\u1086 \uc0\u1082 \uc0\u1072 \uc0\u1079 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1103 \uc0\u1084 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1054 \uc0\u1073 \uc0\u1088 \uc0\u1072 \uc0\u1079 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sl220{\fs22\uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2029\line \uc0\u1042 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1057 \uc0\u1072 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1074 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1085 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1080 \uc0\u1089 \uc0\u1089 \uc0\u1083 \uc0\u1077 \uc0\u1076 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1100 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  \uc0\u1075 \uc0\u1086 \uc0\u1089 \uc0\u1091 \uc0\u1076 \uc0\u1072 \uc0\u1088 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1081  \uc0\u1091 \uc0\u1085 \uc0\u1080 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1089 \uc0\u1080 \uc0\u1090 \uc0\u1077 \uc0\u1090  \uc0\u1080 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1080  \uc0\u1053 .\uc0\u1043 . \uc0\u1063 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1074 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1075 \uc0\u1086 , \uc0\u1057 \uc0\u1072 \uc0\u1088 \uc0\u1072 \uc0\u1090 \uc0\u1086 \uc0\u1074 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1048 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1080 \uc0\u1090 \uc0\u1091 \uc0\u1090  \uc0\u1092 \uc0\u1080 \uc0\u1079 \uc0\u1080 \uc0\u1082 \uc0\u1080 , \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1072 \uc0\u1095 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1086 \uc0\u1084 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2024\line \uc0\u1053 \uc0\u1077 \uc0\u1086 \uc0\u1082 \uc0\u1086 \uc0\u1085 \uc0\u1095 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1077  \uc0\u1074 \uc0\u1099 \uc0\u1089 \uc0\u1096 \uc0\u1077 \uc0\u1077 }\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1040 \uc0\u1082 \uc0\u1072 \uc0\u1076 \uc0\u1077 \uc0\u1084 \uc0\u1080 \uc0\u1103  \uc0\u1075 \uc0\u1088 \uc0\u1072 \uc0\u1078 \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1081  \uc0\u1079 \uc0\u1072 \uc0\u1097 \uc0\u1080 \uc0\u1090 \uc0\u1099  \uc0\u1052 \uc0\u1063 \uc0\u1057  \uc0\u1056 \uc0\u1086 \uc0\u1089 \uc0\u1089 \uc0\u1080 \uc0\u1080 , \uc0\u1061 \uc0\u1080 \uc0\u1084 \uc0\u1082 \uc0\u1080  (\uc0\u1052 \uc0\u1086 \uc0\u1089 \uc0\u1082 \uc0\u1086 \uc0\u1074 \uc0\u1089 \uc0\u1082 \uc0\u1072 \uc0\u1103  \uc0\u1086 \uc0\u1073 \uc0\u1083 \uc0\u1072 \uc0\u1089 \uc0\u1090 \uc0\u1100 )}\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1050 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1085 \uc0\u1086 -\uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1085 \uc0\u1099 \uc0\u1081 , \uc0\u1048 \uc0\u1085 \uc0\u1092 \uc0\u1086 \uc0\u1088 \uc0\u1084 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1080 \uc0\u1089 \uc0\u1090 \uc0\u1077 \uc0\u1084 \uc0\u1099  \uc0\u1080  \uc0\u1090 \uc0\u1077 \uc0\u1093 \uc0\u1085 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  (\uc0\u1080 \uc0\u1085 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1088 )}\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1055 \uc0\u1086 \uc0\u1074 \uc0\u1099 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1074 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080 , \uc0\u1082 \uc0\u1091 \uc0\u1088 \uc0\u1089 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2026}\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086  Agile - Scrum, Kanban, Lean}\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1053 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1103 , \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1086  Agile - Scrum, Kanban, Lean}\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2026}\cell\pard\intbl\itap1\sb250\sl280{\fs24\b \uc0\u1052 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1053 \uc0\u1054 \uc0\u1063 \uc0\u1059  \uc0\u1042 \uc0\u1054  \uc0\u1052 \uc0\u1060 \uc0\u1055 \uc0\u1059  \uc0\u171 \uc0\u1057 \uc0\u1080 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1075 \uc0\u1080 \uc0\u1103 \uc0\u187 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1058 \uc0\u1077 \uc0\u1089 \uc0\u1090 \uc0\u1099 , \uc0\u1101 \uc0\u1082 \uc0\u1079 \uc0\u1072 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2026}\cell\pard\intbl\itap1\sl280{\fs24\b \uc0\u1056 \uc0\u1072 \uc0\u1079 \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1082 \uc0\u1072  \uc0\u1084 \uc0\u1086 \uc0\u1073 \uc0\u1080 \uc0\u1083 \uc0\u1100 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1087 \uc0\u1088 \uc0\u1080 \uc0\u1083 \uc0\u1086 \uc0\u1078 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1092 \uc0\u1080 \uc0\u1090 \uc0\u1085 \uc0\u1077 \uc0\u1089 -\uc0\u1094 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1072 }\par\pard\intbl\itap1\sl260{\fs18 \uc0\u1053 \uc0\u1054 \uc0\u1063 \uc0\u1059  \uc0\u1042 \uc0\u1054  \uc0\u1052 \uc0\u1060 \uc0\u1055 \uc0\u1059  \uc0\u171 \uc0\u1057 \uc0\u1080 \uc0\u1085 \uc0\u1077 \uc0\u1088 \uc0\u1075 \uc0\u1080 \uc0\u1103 \uc0\u187 , \uc0\u1052 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1074 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1069 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1077  \uc0\u1089 \uc0\u1077 \uc0\u1088 \uc0\u1090 \uc0\u1080 \uc0\u1092 \uc0\u1080 \uc0\u1082 \uc0\u1072 \uc0\u1090 \uc0\u1099 }\cell\row\trowd\cellx1800\cellx8600\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 2026}\cell\pard\intbl\itap1\sl260{\fs18 Excel \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1072 \uc0\u1085 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072  \uc0\u1076 \uc0\u1072 \uc0\u1085 \uc0\u1085 \uc0\u1099 \uc0\u1093 \line Soft Skills \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103 \line \uc0\u1048 \uc0\u1085 \uc0\u1089 \uc0\u1090 \uc0\u1088 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1099  \uc0\u1080 \uc0\u1089 \uc0\u1082 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1090 \uc0\u1074 \uc0\u1077 \uc0\u1085 \uc0\u1085 \uc0\u1086 \uc0\u1075 \uc0\u1086  \uc0\u1080 \uc0\u1085 \uc0\u1090 \uc0\u1077 \uc0\u1083 \uc0\u1083 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1076 \uc0\u1083 \uc0\u1103  \uc0\u1088 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1099  \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 \line \uc0\u1052 \uc0\u1077 \uc0\u1090 \uc0\u1086 \uc0\u1076 \uc0\u1086 \uc0\u1083 \uc0\u1086 \uc0\u1075 \uc0\u1080 \uc0\u1080  \uc0\u1091 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1103  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 \uc0\u1084 \uc0\u1080 \line \uc0\u1055 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1085 \uc0\u1072 \uc0\u1103  \uc0\u1076 \uc0\u1086 \uc0\u1082 \uc0\u1091 \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1090 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103 \line \uc0\u1056 \uc0\u1072 \uc0\u1073 \uc0\u1086 \uc0\u1090 \uc0\u1072  \uc0\u1084 \uc0\u1077 \uc0\u1085 \uc0\u1077 \uc0\u1076 \uc0\u1078 \uc0\u1077 \uc0\u1088 \uc0\u1072  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072  \uc0\u1089  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1076 \uc0\u1091 \uc0\u1082 \uc0\u1090 \uc0\u1086 \uc0\u1084 }\cell\pard\intbl\itap1\sl260{\fs18 }\cell\row\trowd\cellx1800\cellx8600\cellx9638\pard\intbl\itap1\sb250\sl220{\fs16\cf3 2025}\cell\pard\intbl\itap1\sb250\sl260{\fs18 \uc0\u1048 \uc0\u1085 \uc0\u1080 \uc0\u1094 \uc0\u1080 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1103  \uc0\u1080  \uc0\u1087 \uc0\u1083 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1088 \uc0\u1086 \uc0\u1074 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 \line \uc0\u1050 \uc0\u1086 \uc0\u1085 \uc0\u1090 \uc0\u1088 \uc0\u1086 \uc0\u1083 \uc0\u1100  \uc0\u1088 \uc0\u1077 \uc0\u1072 \uc0\u1083 \uc0\u1080 \uc0\u1079 \uc0\u1072 \uc0\u1094 \uc0\u1080 \uc0\u1080  \uc0\u1080  \uc0\u1079 \uc0\u1072 \uc0\u1074 \uc0\u1077 \uc0\u1088 \uc0\u1096 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 \line \uc0\u1059 \uc0\u1087 \uc0\u1088 \uc0\u1072 \uc0\u1074 \uc0\u1083 \uc0\u1077 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1082 \uc0\u1086 \uc0\u1084 \uc0\u1072 \uc0\u1085 \uc0\u1076 \uc0\u1086 \uc0\u1081  \uc0\u1087 \uc0\u1088 \uc0\u1086 \uc0\u1077 \uc0\u1082 \uc0\u1090 \uc0\u1072 }\cell\pard\intbl\itap1\sb250\sl260{\fs18 }\cell\row\trowd\cellx9638\pard\intbl\itap1\sa150\sb500\brdrb\brdrs\brdrcf2{\fs22\cf1 \uc0\u1053 \uc0\u1072 \uc0\u1074 \uc0\u1099 \uc0\u1082 \uc0\u1080 }\cell\row\trowd\cellx1800\cellx9638\pard\intbl\itap1\sl220{\fs16\cf3 \uc0\u1047 \uc0\u1085 \uc0\u1072 \uc0\u1085 \uc0\u1080 \uc0\u1077  \uc0\u1103 \uc0\u1079 \uc0\u1099 \uc0\u1082 \uc0\u1086 \uc0\u1074 }\cell\pard\intbl\itap1\sl260{\fs18 \uc0\u1056 \uc0\u1091 \uc0\u1089 \uc0\u1089 \uc0\u1082 \uc0\u1080 \uc0\u1081  {\cf1\emdash  \uc0\u1056 \uc0\u1086 \uc0\u1076 \uc0\u1085 \uc0\u1086 \uc0\u1081 }\par \uc0\u1